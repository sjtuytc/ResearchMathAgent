# ------------------------------
# LaTeX build artifacts
# ------------------------------
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.xdv
/main.pdf

# ------------------------------
# Python build artifacts
# ------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# Beamer / presentation artifacts
*.nav
*.snm
*.vrb

# Temporary / backup files
*~
*.swp
*.swo
*.tmp
*.bak

# OS / editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
.venv/
.deps/

# Google Cloud service account key files (never commit credentials)
gcloud-key*.json
*-service-account.json
*-service-account-key.json
webapp/gcp_key.json
service_account*.json

# Web app agent scratch workspaces
webapp/.runs/
# Issue tracker: commit JSON files; exclude large working proofs and legacy summaries
webapp/issues/**/*.tex
webapp/issues/**/*.md
webapp/issues/**/*.pdf

# Generated daily reports (keep the dir + its README)
documents/*
!documents/README.md

# Data and solver outputs (large, not versioned here)
data/
outputs/
# Except the seed dataset metadata (small, should be in repo)
!data/datasets/
!data/datasets/first_proof_1/
!data/datasets/first_proof_1/metadata.json
!data/datasets/first_proof_1/problems/
!data/datasets/first_proof_1/problems/*.json
!data/datasets/first_proof_2/
!data/datasets/first_proof_2/metadata.json
!data/datasets/first_proof_2/problems/
!data/datasets/first_proof_2/problems/*.json
