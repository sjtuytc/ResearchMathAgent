# Copy this to smoke/secrets.env and fill in real keys.
# Only the providers actually invoked by firstproof_smoke_fast and
# firstproof_smoke_full are needed; the Council uses one model per
# provider.

# REQUIRED: Author + Critic + Council OpenAI seat + (full smoke) Compute Worker.
OPENAI_API_KEY=

# REQUIRED for Council Anthropic seat (sonnet_46).
ANTHROPIC_API_KEY=

# REQUIRED for Council Gemini seat (gemini-3.1-pro).
GOOGLE_API_KEY=

# Optional: keep healthcheck off for the smoke (same default as the real run).
FIRSTPROOF_HEALTHCHECK=off

# Optional: override workflow preset (the run_*.sh scripts set this
# already, but you can override here for ad-hoc invocations).
# FIRSTPROOF_WORKFLOW=firstproof_smoke_fast

# Optional: tighten per-problem budget further if running on a metered key.
# FIRSTPROOF_BUDGET_USD_PER_QUESTION=2.0
# FIRSTPROOF_MAX_PARALLEL=6
# FIRSTPROOF_N_ROUNDS=2
# FIRSTPROOF_PAGE_LIMIT=8
