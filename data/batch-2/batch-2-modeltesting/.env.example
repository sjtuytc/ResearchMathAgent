# Copy to .env and fill in. .env is gitignored.
OPENAI_API_KEY=sk-...

# Cheapest broadly-available OpenAI model as of 2026: gpt-4.1-nano
# (~$0.10/1M input, $0.40/1M output). Override here to test others.
OPENAI_MODEL=gpt-4.1-nano

# Number of concurrent in-flight API calls.
CONCURRENCY=10

# Per-call timeout (seconds) and retry budget.
PER_CALL_TIMEOUT=120
MAX_RETRIES=5
