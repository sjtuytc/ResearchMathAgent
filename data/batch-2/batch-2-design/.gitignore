# Ignore all files in secrets directory
secrets/*
# But keep the directory itself
!secrets/.gitkeep

# Ignore run configuration (contains AWS account details)
run-config.env

# Claude Code local state
.claude/

# Ignore results (contain instance IDs and run artifacts)
results/*
# But keep the directory itself
!results/.gitkeep
# Submitter secrets should live in /secrets/, never inside their repo
submissions/*/secrets.env
