# First Proof — AWS configuration for run.sh
# Copy this file to run-config.env and fill in your values.
# run-config.env is gitignored and must never be committed.

# AWS CLI profile name
AWS_PROFILE=firstproof

# EC2 key pair name (as registered in AWS)
KEY_NAME=firstproof-run

# Path to the corresponding private key on your local machine
KEY_FILE=$HOME/.ssh/firstproof-run.pem

# Security group name (must allow SSH inbound from your IP)
SECURITY_GROUP=firstproof-run-sg

# Default AMI (Ubuntu 24.04 LTS in us-east-1)
# Update this if you change regions.
DEFAULT_AMI=ami-0be45a99d3b2708c6
