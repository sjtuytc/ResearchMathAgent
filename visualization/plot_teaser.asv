function make_teaser_figure(in_dir, out_path, num_frames)
% make_teaser_figure('input/', 'output/teaser.pdf', 4)
% Builds a grid: [camera trajectory | sampled frames]
% Each row = one video; each col = (1 trajectory + N frames)
% The code looks for: *_cam_info.json and corresponding *_render.mp4 or .gif

if nargin < 1, in_dir = 'input'; end
if nargin < 2, out_path = 'output/teaser.pdf'; end
if nargin < 3, num_frames = 4; end

json_files = dir(fullfile(in_dir, '*cam_info.json'));
num_videos = numel(json_files);
if num_videos == 0
    error('No cam_info.json found in "%s"', in_dir);
end

figure('Color','w','Position',[100 100 300*num_frames 220*num_videos]);
tiledlayout(num_videos, num_frames+1, 'Padding','compact', 'TileSpacing','compact');

for v = 1:num_videos
    json_path = fullfile(json_files(v).folder, json_files(v).name);
    [~, base, ~] = fileparts(json_path);
    fprintf('Plotting %s ...\n', base);

    % === 1. Camera trajectory subplot ===
    nexttile;
    plot_camera_sub(json_path);
    title(sprintf('%s', base), 'Interpreter','none', 'FontSize',9);

    % === 2. Sample video frames ===
    vid_path = fullfile(in_dir, [base '_render.mp4']);
    if ~isfile(vid_path)
        alt = strrep(vid_path, '.mp4', '.gif');
        if isfile(alt), vid_path = alt; else, vid_path = ''; end
    end

    if isempty(vid_path)
        for j = 1:num_frames
            nexttile; axis off;
            text(0.5,0.5,'(no video)', 'HorizontalAlignment','center');
        end
    else
        try
            v = VideoReader(vid_path);
            totalF = v.NumFrames;
            frame_ids = round(linspace(1, totalF, num_frames));
            for j = 1:num_frames
                nexttile;
                img = read(v, frame_ids(j));
                imshow(img);
                axis off;
            end
        catch
            warning('Failed reading %s', vid_path);
            for j = 1:num_frames
                nexttile; axis off;
                text(0.5,0.5,'(read err)', 'HorizontalAlignment','center');
            end
        end
    end
end

exportgraphics(gcf, out_path, 'ContentType','vector');
fprintf('Saved teaser to %s\n', out_path);
close(gcf);
end



function plot_single_cam(json_path, out_pdf)
% Visualize camera trajectory from cam_info.json (w2c extrinsics).
% Shows time-colored centers, grey path, start/end markers, one arrow,
% and optional tiny frustums.
close all;

if nargin < 1
    error('Usage: plot_cam_info(''path/to/cam_info.json'')');
end

% --- Load JSON ---
raw = fileread(json_path);
J   = jsondecode(raw);

% Fields expected: intrinsic [F,3,3], extrinsic [F,3,4] or [F,4,4], height, width
K_all = squeeze2(J.intrinsic);   % F x 3 x 3
E_all = squeeze2(J.extrinsic);   % F x 3 x 4  (or 4x4)
H = J.height; W = J.width;

F = size(E_all,1);
if F < 2, error('Need at least 2 poses to draw a trajectory.'); end

% --- Normalize extrinsics to [R|t] with 3x4 w2c ---
if size(E_all,2)==4 && size(E_all,3)==4
    % 4x4 -> 3x4
    Rt = zeros(F,3,4);
    for i=1:F
        Rt(i,:,:) = E_all(i,1:3,1:4);
    end
    E = Rt;
elseif size(E_all,2)==3 && size(E_all,3)==4
    E = E_all;
else
    error('Unexpected extrinsic shape. Expect Fx3x4 or Fx4x4.');
end

% --- Camera centers in world (from w2c: Xc = R*Xw + t, C = -R''*t) ---
C = zeros(F,3);
for i = 1:F
    R = double(squeeze(E(i,1:3,1:3)));      % 3x3
    t = double(squeeze(E(i,1:3,4)));        % 3x1 (enforce)
    t = t(:);                               % make sure it's column (3x1)
    Cw = -R.' * t;                          % 3x1
    C(i,:) = Cw.';                          % store row (1x3)
end

% --- Plot ---
figure('Color','w'); ax = axes; hold(ax,'on'); grid(ax,'on'); axis(ax,'equal');
xlabel('X'); ylabel('Y'); zlabel('Z');

tlin = linspace(0,1,F);
scatter3(C(:,1),C(:,2),C(:,3), 18, tlin, 'filled');               % time-colored centers
colormap(ax, 'turbo'); 
%colorbar;                                   % time colorbar
plot3(C(:,1),C(:,2),C(:,3), '-', 'Color',[0.5 0.5 0.5], 'LineWidth',1.0); % grey path

% === Start & End markers with adaptive offset text ===
plot3(C(1,1),C(1,2),C(1,3),'p','MarkerSize',10,...
    'MarkerFaceColor',[0.2 1 0.2],'MarkerEdgeColor','k');
plot3(C(end,1),C(end,2),C(end,3),'p','MarkerSize',10,...
    'MarkerFaceColor',[1 0.2 0.2],'MarkerEdgeColor','k');

% --- Compute trajectory scale and dominant direction ---
scene_extent = max(range(C(:,1)), max(range(C(:,2)), range(C(:,3))));
if scene_extent == 0, scene_extent = norm(C(end,:) - C(1,:)) + 1e-6; end
dir_main = C(end,:) - C(1,:);
dir_main = dir_main / max(norm(dir_main), eps);

% --- Find a stable perpendicular direction for lateral offset ---
% Use SVD of the trajectory covariance for stability
[~,~,Vcov] = svd(cov(C));
if isempty(Vcov)
    lat_dir = null(dir_main);  % fallback if path is degenerate
else
    lat_dir = Vcov(:,end);     % pick least-varying direction
end
if isempty(lat_dir), lat_dir = [0;1;0]; end
lat_dir = lat_dir(:)' / max(norm(lat_dir), eps);

% Ensure orthogonality
lat_dir = lat_dir - dir_main * dot(lat_dir, dir_main);
lat_dir = lat_dir / max(norm(lat_dir), eps);

% --- Adaptive offsets ---
start_offset_mag = 0.05 * scene_extent;   % moderate
end_offset_mag   = 0.10 * scene_extent;   % farther away
up_dir = cross(dir_main, lat_dir);
up_dir = up_dir / max(norm(up_dir), eps);

% shift both laterally and slightly upward
offset_start =  start_offset_mag * (0.6*lat_dir + 0.4*up_dir);
offset_end   =  end_offset_mag   * (0.6*lat_dir + 0.4*up_dir);

start_pos = C(1,:)   + offset_start;
end_pos   = C(end,:) + offset_end;

% --- Draw text labels ---
text(start_pos(1), start_pos(2), start_pos(3), '  START', ...
    'FontSize',10,'FontWeight','bold','Color',[0.1 0.5 0.1], ...
    'HorizontalAlignment','left','VerticalAlignment','bottom');

text(end_pos(1), end_pos(2), end_pos(3), '  END', ...
    'FontSize',10,'FontWeight','bold','Color',[0.7 0 0], ...
    'HorizontalAlignment','left','VerticalAlignment','bottom');

% One orientation arrow aligned with actual motion along the curve
k = max(1, min(F-1, round(0.7*(F-1))));
vec = C(k+1,:) - C(k,:);
nv  = norm(vec);
if nv > 1e-8, vec = vec / nv; else, vec = [1 0 0]; end % fallback
scale = max(range(C(:,1)), max(range(C(:,2)), range(C(:,3))));
if scale==0, scale=1; end
arrow_len = 0.22 * scale;
quiver3(C(k,1),C(k,2),C(k,3), vec(1),vec(2),vec(3), arrow_len, ...
        'Color',[1 0.5 0], 'LineWidth',2, 'MaxHeadSize',0.5);

% Optional: draw tiny frustums every ~F/8 frames (lightweight)
draw_every = max(1, round(F/10));
for i=2:draw_every:F-1
    R = squeeze(E(i,1:3,1:3));
    t = squeeze(E(i,1:3,4));
    K = K_all;
    draw_frustum(K, R, t, W, H, 0.05*scale, ax); % 5% of scene
end

% Nice view / limits
mid = mean(C,1);
r   = 0.55 * scale;
xlim([mid(1)-r, mid(1)+r]); ylim([mid(2)-r, mid(2)+r]); zlim([mid(3)-r, mid(3)+r]);
% === View and export ===
view(20,35);
axis vis3d;
set(gca,'FontSize',10,'LineWidth',1);
set(gcf,'PaperPositionMode','auto');
exportgraphics(gcf, out_pdf, 'ContentType','vector');
close(gcf);
end % function

% ---------- helpers ----------
function A = squeeze2(A)
% Convert nested cell->array if needed, otherwise return A
if iscell(A)
    A = cellfun(@double, A, 'UniformOutput', false);
    A = cat(1, A{:});
else
    A = double(A);
end
end

function s = strip_filename(p)
[~,s,~] = fileparts(p);
end

function draw_frustum(K, R, t, W, H, depth_scale, ax, convention)
% Draw a tiny frustum from extrinsics.
% convention: 'w2c' (default) means Xc = R*Xw + t, so Cw = -R'*t
%             'c2w' means Xw = R*Xc + t, so Cw = t

if nargin < 8 || isempty(convention)
    convention = 'w2c';
end

% force numeric types and shapes
K = double(K);
R = double(R);
t = double(t(:));         % make 3x1 column

% Camera center in world
switch lower(convention)
    case 'w2c'
        Cw = -R.' * t;    % 3x1
    case 'c2w'
        Cw =  t;          % 3x1
    otherwise
        error('Unknown convention: %s (use ''w2c'' or ''c2w'')', convention);
end

% Corner pixels (u,v,1)
corners = [0   0   1;
           W-1 0   1;
           W-1 H-1 1;
           0   H-1 1]';

% Rays in camera coords
ray_cam = K \ corners;        % 3x4

% Bring rays to world coords
switch lower(convention)
    case 'w2c'
        ray_w = R.' * ray_cam;  % 3x4
    case 'c2w'
        ray_w = R   * ray_cam;  % 3x4
end

% Normalize and scale
ray_w = ray_w ./ vecnorm(ray_w,2,1);
ends  = Cw.' + depth_scale * ray_w.';   % 4x3

% Draw pyramid edges
for i = 1:4
    plot3(ax, [Cw(1) ends(i,1)], [Cw(2) ends(i,2)], [Cw(3) ends(i,3)], '-', ...
        'Color',[0.2 0.6 1], 'LineWidth',0.8);
end
% Base rectangle
idx = [1 2 3 4 1];
plot3(ax, ends(idx,1), ends(idx,2), ends(idx,3), '-', ...
    'Color',[0.2 0.6 1], 'LineWidth',0.8);


end

%plot_cam_infos('flux-0_free1_cam_info.json');

batch_plot_cam_info();